# Prumo — variáveis de ambiente
#
# Regra de ouro: NENHUM segredo no client. Tudo que começa com VITE_ é embutido
# no bundle e fica PÚBLICO. Só coloque aqui o que pode ser lido por qualquer um.
# Segredos de verdade (chaves de API privadas, credenciais de banco) vivem apenas
# no backend — nunca neste arquivo, nunca com o prefixo VITE_.

# URL base da API. Em produção, aponte para o gateway que serve os headers de
# segurança e mantém a sessão em cookie httpOnly (ver SECURITY.md).
VITE_API_BASE_URL=/api

# ---------------------------------------------------------------------------
# BACKEND (server/ + api/) — estas variáveis NÃO têm prefixo VITE_ e por isso
# NUNCA chegam ao cliente. Ficam só no servidor / painel da Vercel.
# ---------------------------------------------------------------------------

# Connection string do MongoDB Atlas. Se deixar em branco em desenvolvimento,
# o servidor sobe um MongoDB em memória automaticamente (roda sem configurar).
# Em produção é OBRIGATÓRia.
MONGODB_URI=

# Segredo para assinar a sessão (JWT). Gere um valor longo e aleatório.
# Ex.: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Porta do servidor de API em desenvolvimento (o Vite faz proxy para ela).
PORT=3001
